---
import { getTranslations } from '../i18n/utils';

interface Props {
  currentLocale: 'en' | 'he';
}

const { currentLocale } = Astro.props;
const t = getTranslations(currentLocale);

const isHe = currentLocale === 'he';
const contactHref = isHe ? '/he/contact' : '/contact';
---

<!--
  Hero section. Full viewport height. Atmospheric radial gradient background.
  RTL: text-align right (via [dir="rtl"] in global.css), CTA row flows
  inline-end → inline-start (right to left in RTL). No markup duplication.
-->
<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__content">

    <!-- Eyebrow label -->
    <p class="hero__eyebrow">{t.hero.eyebrow}</p>

    <!-- H1 — developer name -->
    <h1 id="hero-heading" class="hero__name">{t.hero.name}</h1>

    <!-- Tagline -->
    <p class="hero__tagline">{t.hero.tagline}</p>

    <!-- Decorative gold rule — centred regardless of text direction -->
    <div class="hero__rule-wrapper" aria-hidden="true">
      <hr class="hero__rule" />
    </div>

    <!-- CTA buttons — inline-flex row, RTL-aware via logical properties -->
    <div class="hero__ctas">
      <a href="#projects" class="btn-primary hero__cta-primary">
        {t.hero.ctaPrimary}
      </a>
      <a href={contactHref} class="btn-secondary hero__cta-secondary">
        {t.hero.ctaSecondary}
      </a>
    </div>

  </div>
</section>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    /* Atmospheric radial gradient: warm off-white at centre, slightly warmer cream at edges */
    background: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      var(--color-surface) 0%,
      #F5F0E8 100%
    );
    /* Offset for fixed navbar (4rem height) */
    padding-top: 4rem;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    /* In LTR: items align to inline-start (left).
       In RTL (dir="rtl" on <html>): items align to inline-start (right). */
    align-items: flex-start;
    padding-block: 5rem;
    max-width: 760px;
  }

  /* Eyebrow: small, sage green */
  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-sage);
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  /* H1: Satoshi Bold, responsive per type scale */
  .hero__name {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: var(--leading-heading);
    color: var(--color-ink);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  /* Tagline: body text, generous line height */
  .hero__tagline {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  /* Gold rule wrapper: always centred within the content column */
  .hero__rule-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  /* Decorative rule: 1px gold, 60px wide */
  .hero__rule {
    width: 60px;
    height: 1px;
    border: none;
    background-color: var(--color-gold);
    flex-shrink: 0;
  }

  /* CTA row: inline flex, wraps on small screens */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  /* ── RTL overrides ── */
  /* When dir="rtl" is on <html>, text-align defaults to right (global.css).
     The flex column and CTA row follow inline direction automatically.
     We explicitly align the content column to inline-start (right in RTL). */
  [dir="rtl"] .hero__content {
    align-items: flex-end;
  }

  /* Rule wrapper remains centred in RTL */
  [dir="rtl"] .hero__rule-wrapper {
    justify-content: center;
  }

  /* Tagline max-width still readable in RTL */
  [dir="rtl"] .hero__tagline {
    max-width: 540px;
  }
</style>
