---
import { getTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  stack: string[];
  valueDelivered: string;
  liveUrl: string | null;
  screenshotSrc: string | null;
  isPlaceholder: boolean;
  currentLocale: 'en' | 'he';
}

const {
  title,
  description,
  stack,
  valueDelivered,
  liveUrl,
  screenshotSrc,
  isPlaceholder,
  currentLocale,
} = Astro.props;

const t = getTranslations(currentLocale);

// The live site link aria-label is derived from the project title if no specific
// key exists at the section level — each project passes its own liveLinkAriaLabel.
// This component receives all strings as props from ProjectsSection.
---

<article class="card project-card">

  <!-- Screenshot / Placeholder area — 16:9 aspect ratio -->
  <div class="project-card__media">
    {screenshotSrc !== null ? (
      <img
        src={screenshotSrc}
        alt={title}
        class="project-card__screenshot"
        loading="lazy"
        decoding="async"
        width="1200"
        height="675"
      />
    ) : (
      <div class="project-card__placeholder" aria-hidden="true">
        <p class="project-card__placeholder-text">{t.projects.previewComing}</p>
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="project-card__body">

    <!-- Title -->
    <h3 class="project-card__title">{title}</h3>

    <!-- Description -->
    <p class="project-card__description">{description}</p>

    <!-- Tech stack pills -->
    <div class="project-card__stack">
      {stack.map((tech) => (
        <span class="pill">{tech}</span>
      ))}
    </div>

    <!-- Value Delivered -->
    <div class="project-card__value">
      <p class="label-uppercase project-card__value-label">
        {t.projects.valueDeliveredLabel}
      </p>
      <p class="project-card__value-text">{valueDelivered}</p>
    </div>

    <!--
      Live site link — ONLY rendered when liveUrl is not null.
      When liveUrl is null, no anchor element is output — not even disabled.
      This is a hard constraint from the build spec.
    -->
    {liveUrl !== null && (
      <a
        href={liveUrl}
        class="project-card__live-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span>{t.projects.viewLiveSite}</span>
        <svg
          class="project-card__live-icon icon-directional"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M3 3h8m0 0v8m0-8L3 11"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    )}

  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* ── Media / screenshot area ── */
  .project-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-cream);
    flex-shrink: 0;
  }

  .project-card__screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-card__screenshot {
    transform: scale(1.02);
  }

  /* Placeholder state */
  .project-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px dashed color-mix(in srgb, var(--color-accent) 40%, transparent);
    background-color: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .project-card__placeholder-text {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-accent);
    text-align: center;
    padding-inline: 1.5rem;
    line-height: 1.5;
  }

  /* ── Card body ── */
  .project-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem;
    gap: 1rem;
  }

  /* Title */
  .project-card__title {
    font-family: var(--font-heading);
    font-size: 1.1875rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0;
  }

  /* Description */
  .project-card__description {
    font-family: var(--font-body);
    font-size: var(--text-small);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
    margin: 0;
    flex: 1;
  }

  /* Tech stack pill row */
  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* Value Delivered block */
  .project-card__value {
    padding: 0.875rem 1rem;
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
    border-inline-start: 3px solid var(--color-sage);
    border-radius: 0 var(--radius-pill) var(--radius-pill) 0;
  }

  .project-card__value-label {
    margin-bottom: 0.25rem;
  }

  .project-card__value-text {
    font-family: var(--font-body);
    font-size: var(--text-small);
    line-height: var(--leading-body);
    color: var(--color-ink);
    margin: 0;
  }

  /* Live site link */
  .project-card__live-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: auto;
    transition: color 0.15s ease, gap 0.15s ease;
    align-self: flex-start;
  }

  .project-card__live-link:hover {
    color: var(--color-accent-dark);
    gap: 0.55rem;
  }

  .project-card__live-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .project-card__live-icon {
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  /* ── RTL: value border flips to inline-start (right) ── */
  [dir="rtl"] .project-card__value {
    border-inline-start: 3px solid var(--color-sage);
    border-radius: var(--radius-pill) 0 0 var(--radius-pill);
  }

  [dir="rtl"] .project-card__live-link {
    align-self: flex-end;
  }
</style>
