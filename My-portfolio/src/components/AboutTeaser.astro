---
import { getTranslations } from '../i18n/utils';

interface Props {
  currentLocale: 'en' | 'he';
}

const { currentLocale } = Astro.props;
const t = getTranslations(currentLocale);

const isHe = currentLocale === 'he';
const aboutHref = isHe ? '/he/about' : '/about';
---

<!--
  About teaser section on the home page.
  Renders the SG monogram SVG inline alongside a short biography paragraph.
  Monogram.astro is created in Phase 5 (About pages); the SVG is inlined here
  directly so Phase 4 has no cross-phase import dependency.

  RTL: The two-column layout uses flex with row-reverse via [dir="rtl"] rule,
  placing the monogram on the right and bio text on the left.
  The read-more directional arrow uses .icon-directional class; global.css
  mirrors it via [dir="rtl"] .icon-directional { transform: scaleX(-1) }.
  The arrow character itself is NOT stored in the language file — it is rendered
  as a CSS-controlled visual element only.
-->
<section class="about-teaser section-padding" aria-labelledby="about-teaser-heading">
  <div class="container about-teaser__inner">

    <!--
      SG Monogram — inline SVG (matches the spec for Monogram.astro).
      120×120px circle, #FAF9F6 fill, #A47864 1.5px stroke, "SG" centred.
      aria-label from language file.
    -->
    <div class="about-teaser__monogram-wrapper" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 120 120"
        width="120"
        height="120"
        role="img"
        aria-label={t.about.monogramAriaLabel}
        class="about-teaser__monogram"
      >
        <circle cx="60" cy="60" r="58" fill="#FAF9F6" stroke="#A47864" stroke-width="1.5" />
        <text
          x="60"
          y="60"
          text-anchor="middle"
          dominant-baseline="central"
          font-family="'Satoshi', system-ui, -apple-system, sans-serif"
          font-weight="700"
          font-size="38"
          fill="#1F1F1F"
          letter-spacing="-1"
        >SG</text>
      </svg>
    </div>

    <!-- Bio text and read-more link -->
    <div class="about-teaser__content">
      <p class="about-teaser__text">{t.aboutTeaser.text}</p>

      <!--
        Read-more link.
        The directional arrow (→ in LTR, ← in RTL) is a separate <span>
        marked .icon-directional so global.css can mirror it with scaleX(-1).
        The text ("Read More" / "קרא עוד") lives in the language file.
        The arrow is never duplicated in the language files.
      -->
      <a href={aboutHref} class="about-teaser__read-more">
        {t.aboutTeaser.readMore}
        <span class="about-teaser__arrow icon-directional" aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>

<style>
  .about-teaser {
    background-color: var(--color-surface);
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
  }

  /* Two-column layout: monogram + bio text side by side */
  .about-teaser__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .about-teaser__inner {
      flex-direction: row;
      align-items: center;
      gap: 3.5rem;
    }
  }

  /* Monogram wrapper — prevents shrinking */
  .about-teaser__monogram-wrapper {
    flex-shrink: 0;
  }

  .about-teaser__monogram {
    display: block;
  }

  /* Bio content column */
  .about-teaser__content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-teaser__text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
    max-width: 540px;
  }

  /* Read-more link */
  .about-teaser__read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.15s ease, color 0.15s ease;
  }

  .about-teaser__read-more:hover {
    color: var(--color-accent-dark);
    gap: 0.65rem;
  }

  .about-teaser__read-more:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .about-teaser__arrow {
    display: inline-block;
    font-style: normal;
    line-height: 1;
    /* transition applied so hover gap animation is smooth */
    transition: transform 0.15s ease;
  }

  /* ── RTL: reverse two-column order on desktop ──
     Monogram goes to the right (inline-end), bio text to the left (inline-start).
     flex-direction: row-reverse achieves this without markup duplication.
  */
  @media (min-width: 640px) {
    [dir="rtl"] .about-teaser__inner {
      flex-direction: row-reverse;
    }
  }

  /* Arrow mirrors via global.css [dir="rtl"] .icon-directional { transform: scaleX(-1) } */
</style>
