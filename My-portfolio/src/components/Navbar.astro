---
import { getTranslations } from '../i18n/utils';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  currentLocale: 'en' | 'he';
  currentPath: string;
}

const { currentLocale, currentPath } = Astro.props;
const t = getTranslations(currentLocale);

const isHe = currentLocale === 'he';

// Nav link definitions — paths differ by locale
const navLinks = [
  { labelKey: 'home' as const,    href: isHe ? '/he/' : '/' },
  { labelKey: 'about' as const,   href: isHe ? '/he/about' : '/about' },
  { labelKey: 'contact' as const, href: isHe ? '/he/contact' : '/contact' },
];

// Normalise trailing slash for active comparison (but preserve lone /)
function normalizePath(p: string): string {
  return p.length > 1 && p.endsWith('/') ? p.slice(0, -1) : p;
}

function isActive(href: string): boolean {
  return normalizePath(href) === normalizePath(currentPath);
}
---

<!--
  Fixed navbar. Background #1F1F1F (dark charcoal).
  Layout order in DOM: logo → nav → controls.
  With dir="rtl" on <html>, flexbox row reverses automatically:
    LTR: logo (left) | nav (centre) | controls (right)
    RTL: controls (left) | nav (centre) | logo (right)
  This is genuine RTL mirroring — no markup duplication.
-->
<header class="navbar" role="banner">
  <div class="container navbar__inner">

    <!-- Brand / Logo — always first in DOM -->
    <a
      href={isHe ? '/he/' : '/'}
      class="navbar__brand"
      aria-label={t.hero.name}
    >
      {t.hero.name}
    </a>

    <!-- Desktop navigation links — centred via flex: 1 -->
    <nav class="navbar__nav" aria-label={t.nav.home}>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['navbar__link', { 'navbar__link--active': isActive(link.href) }]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {t.nav[link.labelKey]}
        </a>
      ))}
    </nav>

    <!-- Controls: email + language toggle + hamburger (mobile only) -->
    <div class="navbar__controls">
      <!-- Email link — desktop only -->
      <a
        href={`mailto:${t.email}`}
        class="navbar__email"
        aria-label={t.nav.emailAriaLabel}
      >
        {t.email}
      </a>

      <!-- Language toggle -->
      <LanguageToggle currentLocale={currentLocale} currentPath={currentPath} />

      <!-- Hamburger button — mobile only -->
      <button
        id="hamburger-btn"
        class="hamburger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t.nav.menuOpenAriaLabel}
        data-open-label={t.nav.menuOpenAriaLabel}
        data-close-label={t.nav.menuCloseAriaLabel}
      >
        <!-- Three-line icon (shown when closed) -->
        <svg
          id="icon-menu"
          width="22"
          height="22"
          viewBox="0 0 22 22"
          fill="none"
          aria-hidden="true"
          focusable="false"
        >
          <rect x="2" y="5" width="18" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="10" width="18" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="15" width="18" height="2" rx="1" fill="currentColor" />
        </svg>
        <!-- X icon (shown when open) -->
        <svg
          id="icon-close"
          width="22"
          height="22"
          viewBox="0 0 22 22"
          fill="none"
          aria-hidden="true"
          focusable="false"
          style="display: none;"
        >
          <line x1="4" y1="4" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="18" y1="4" x2="4" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu — hidden until hamburger opens it -->
  <div
    id="mobile-menu"
    class="mobile-menu"
    aria-hidden="true"
    role="navigation"
    aria-label={t.nav.home}
  >
    <div class="container mobile-menu__inner">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['mobile-menu__link', { 'mobile-menu__link--active': isActive(link.href) }]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {t.nav[link.labelKey]}
        </a>
      ))}
      <a
        href={`mailto:${t.email}`}
        class="mobile-menu__email"
        aria-label={t.nav.emailAriaLabel}
      >
        {t.email}
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Navbar shell ── */
  .navbar {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 1000;
    background-color: var(--color-ink);
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    height: 4rem;
    gap: 1rem;
  }

  /* ── Brand ── */
  .navbar__brand {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.0625rem;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  .navbar__brand:hover {
    opacity: 0.8;
  }

  /* ── Desktop nav — takes up remaining middle space ── */
  .navbar__nav {
    display: none; /* hidden on mobile */
    flex: 1;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
  }

  .navbar__link {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }

  .navbar__link:hover {
    color: #ffffff;
  }

  .navbar__link--active {
    color: #ffffff;
    border-bottom-color: var(--color-gold);
  }

  .navbar__link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── Controls bar ── */
  .navbar__controls {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* ── Email link (desktop only) ── */
  .navbar__email {
    display: none; /* shown at md */
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .navbar__email:hover {
    color: #ffffff;
  }

  .navbar__email:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── Hamburger button (mobile only) ── */
  .hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 0;
    border-radius: 4px;
    transition: opacity 0.15s ease;
    flex-shrink: 0;
  }

  .hamburger:hover {
    opacity: 0.8;
  }

  .hamburger:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
  }

  /* ── Mobile menu ── */
  .mobile-menu {
    display: none;
    background-color: var(--color-ink);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .mobile-menu[aria-hidden="false"] {
    display: block;
  }

  .mobile-menu__inner {
    display: flex;
    flex-direction: column;
    padding-block: 1rem;
    gap: 0.125rem;
  }

  .mobile-menu__link,
  .mobile-menu__email {
    display: block;
    padding: 0.625rem 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease;
  }

  .mobile-menu__link:hover,
  .mobile-menu__email:hover {
    color: #ffffff;
  }

  .mobile-menu__link--active {
    color: #ffffff;
    border-bottom-color: var(--color-gold);
  }

  .mobile-menu__link:focus-visible,
  .mobile-menu__email:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .mobile-menu__email {
    margin-top: 0.5rem;
    padding-top: 0.875rem;
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.5);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* ── Responsive: md (768px) and up ── */
  @media (min-width: 768px) {
    .navbar__nav {
      display: flex;
    }

    .navbar__email {
      display: block;
    }

    .hamburger {
      display: none;
    }
  }
</style>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconMenu = document.getElementById('icon-menu') as SVGElement | null;
  const iconClose = document.getElementById('icon-close') as SVGElement | null;

  if (hamburgerBtn && mobileMenu && iconMenu && iconClose) {
    hamburgerBtn.addEventListener('click', () => {
      const isOpen = hamburgerBtn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        // Close
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        hamburgerBtn.setAttribute('aria-label', hamburgerBtn.dataset.openLabel ?? '');
        mobileMenu.setAttribute('aria-hidden', 'true');
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
      } else {
        // Open
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        hamburgerBtn.setAttribute('aria-label', hamburgerBtn.dataset.closeLabel ?? '');
        mobileMenu.setAttribute('aria-hidden', 'false');
        iconMenu.style.display = 'none';
        iconClose.style.display = '';
      }
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && hamburgerBtn.getAttribute('aria-expanded') === 'true') {
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        hamburgerBtn.setAttribute('aria-label', hamburgerBtn.dataset.openLabel ?? '');
        mobileMenu.setAttribute('aria-hidden', 'true');
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
        hamburgerBtn.focus();
      }
    });

    // Close menu on window resize to desktop breakpoint
    const mediaQuery = window.matchMedia('(min-width: 768px)');
    mediaQuery.addEventListener('change', (e: MediaQueryListEvent) => {
      if (e.matches && hamburgerBtn.getAttribute('aria-expanded') === 'true') {
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        hamburgerBtn.setAttribute('aria-label', hamburgerBtn.dataset.openLabel ?? '');
        mobileMenu.setAttribute('aria-hidden', 'true');
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
      }
    });
  }
</script>
