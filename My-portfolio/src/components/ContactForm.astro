---
import { getTranslations } from '../i18n/utils';

interface Props {
  currentLocale: 'en' | 'he';
}

const { currentLocale } = Astro.props;
const t = getTranslations(currentLocale);

const isHe = currentLocale === 'he';
const formDir = isHe ? 'rtl' : 'ltr';
---

<!--
  ContactForm.astro
  Submits to Formspree via fetch POST with Content-Type: application/json.
  Standard HTML form action is NOT used — it would navigate away from the page.
  All four states are fully implemented:
    1. default  — form fully visible and interactive
    2. sending  — button disabled, text changes to sending string
    3. success  — form hidden, success message with green checkmark shown
    4. error    — error message shown below form, form remains interactive
  All visible strings from i18n language files.
  RTL: labels align right, inputs carry dir attribute, button aligns inline-end.
-->

<!-- Success state — hidden until form submits successfully -->
<div
  id="form-success"
  class="form-success"
  aria-live="polite"
  aria-atomic="true"
  hidden
>
  <!-- Green checkmark SVG -->
  <svg
    class="form-success__icon"
    width="48"
    height="48"
    viewBox="0 0 48 48"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <circle cx="24" cy="24" r="22" fill="color-mix(in srgb, #22c55e 15%, transparent)" stroke="#22c55e" stroke-width="2"/>
    <path
      d="M14 24l7 7 13-14"
      stroke="#22c55e"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
  <h3 class="form-success__heading">{t.contact.form.successHeading}</h3>
  <p class="form-success__message">{t.contact.form.successMessage}</p>
</div>

<!-- The form itself — hidden after successful submission -->
<form
  id="contact-form"
  class="contact-form"
  novalidate
  dir={formDir}
>
  <!-- Name field -->
  <div class="form-field">
    <label for="contact-name" class="form-label">
      {t.contact.form.nameLabel}
    </label>
    <input
      type="text"
      id="contact-name"
      name="name"
      class="form-input"
      placeholder={t.contact.form.namePlaceholder}
      required
      autocomplete="name"
    />
  </div>

  <!-- Email field -->
  <div class="form-field">
    <label for="contact-email" class="form-label">
      {t.contact.form.emailLabel}
    </label>
    <input
      type="email"
      id="contact-email"
      name="email"
      class="form-input"
      placeholder={t.contact.form.emailPlaceholder}
      required
      autocomplete="email"
    />
  </div>

  <!-- Message field -->
  <div class="form-field">
    <label for="contact-message" class="form-label">
      {t.contact.form.messageLabel}
    </label>
    <textarea
      id="contact-message"
      name="message"
      class="form-input form-input--textarea"
      placeholder={t.contact.form.messagePlaceholder}
      rows={4}
      required
    ></textarea>
  </div>

  <!-- Error message — shown on submission failure, hidden by default -->
  <div
    id="form-error"
    class="form-error"
    aria-live="assertive"
    aria-atomic="true"
    hidden
  >
    {t.contact.form.errorMessage}
  </div>

  <!-- Submit button -->
  <button
    type="submit"
    id="form-submit"
    class="btn-primary form-submit"
    data-default-text={t.contact.form.submitButton}
    data-sending-text={t.contact.form.sendingButton}
  >
    {t.contact.form.submitButton}
  </button>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 560px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-input--textarea {
    resize: vertical;
    min-height: 120px;
    line-height: var(--leading-body);
  }

  /* Error message */
  .form-error {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.75rem 1rem;
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: var(--radius-pill);
    line-height: 1.5;
  }

  /* Submit button: full width on mobile, auto on desktop */
  .form-submit {
    align-self: flex-start;
    min-width: 180px;
  }

  .form-submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  /* ── Success state ── */
  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 2rem;
    text-align: center;
    max-width: 480px;
  }

  .form-success__icon {
    flex-shrink: 0;
  }

  .form-success__heading {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    line-height: var(--leading-heading);
  }

  .form-success__message {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--color-ink) 75%, transparent);
  }

  /* ── RTL: submit button aligns to inline-end (right) ── */
  [dir="rtl"] .form-submit {
    align-self: flex-end;
  }

  /* RTL: success state remains centred */
  [dir="rtl"] .form-success {
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement | null;
  const errorDiv = document.getElementById('form-error') as HTMLElement | null;
  const successDiv = document.getElementById('form-success') as HTMLElement | null;

  if (form && submitBtn && errorDiv && successDiv) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      const defaultText = submitBtn.dataset.defaultText ?? '';
      const sendingText = submitBtn.dataset.sendingText ?? '';

      // ── Sending state ──
      submitBtn.disabled = true;
      submitBtn.textContent = sendingText;
      errorDiv.hidden = true;

      // Gather form data as JSON
      const formData = new FormData(form);
      const payload: Record<string, string> = {};
      formData.forEach((value, key) => {
        payload[key] = value.toString();
      });

      try {
        const response = await fetch('https://formspree.io/f/xnjgdpnv', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          // ── Success state ──
          form.hidden = true;
          successDiv.hidden = false;
          // Move focus to success message for screen readers
          successDiv.setAttribute('tabindex', '-1');
          successDiv.focus();
        } else {
          // ── Error state — non-2xx response ──
          submitBtn.disabled = false;
          submitBtn.textContent = defaultText;
          errorDiv.hidden = false;
        }
      } catch {
        // ── Error state — network failure ──
        submitBtn.disabled = false;
        submitBtn.textContent = defaultText;
        errorDiv.hidden = false;
      }
    });
  }
</script>
