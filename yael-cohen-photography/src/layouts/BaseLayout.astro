---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFAB from '../components/WhatsAppFAB.astro';
import { isRTL, getAlternatePath } from '../i18n/utils';
import type { Locale } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  lang: Locale;
  dir?: string;
  pageTitle: string;
  pageDescription: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl: string;
}

const {
  lang,
  pageTitle,
  pageDescription,
  ogTitle,
  ogDescription,
  canonicalUrl,
} = Astro.props;

const resolvedDir = Astro.props.dir ?? (isRTL(lang) ? 'rtl' : 'ltr');
const ogLocale = lang === 'he' ? 'he_IL' : 'en_US';
const resolvedOgTitle = ogTitle ?? pageTitle;
const resolvedOgDescription = ogDescription ?? pageDescription;

const siteBase = 'https://yaelcohen.photography';

// Derive the path segment from the canonical URL so we can compute alternates.
const currentPath = canonicalUrl.startsWith(siteBase)
  ? canonicalUrl.slice(siteBase.length) || '/'
  : '/';

const alternatePath = getAlternatePath(currentPath, lang);

const heUrl = lang === 'he' ? canonicalUrl : `${siteBase}${alternatePath}`;
const enUrl = lang === 'en' ? canonicalUrl : `${siteBase}${alternatePath}`;
---

<!DOCTYPE html>
<html lang={lang} dir={resolvedDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="he" href={heUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={heUrl} />
  </head>
  <body>
    <Navigation lang={lang} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <WhatsAppFAB lang={lang} />
    <Footer lang={lang} />
  </body>
</html>
