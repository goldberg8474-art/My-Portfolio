---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContent from '../components/AboutContent.astro';
import { t } from '../i18n/utils';

const lang = 'he' as const;
const dir  = 'rtl';

// ── CMS data ─────────────────────────────────────────────────────────────────
const seoEntries   = await getCollection('pagesSeo');
const seoEntry     = seoEntries.find(e => e.data.page === 'about');

const aboutEntries = await getCollection('aboutPage');
const aboutContent = aboutEntries[0]?.data;

// ── SEO values ────────────────────────────────────────────────────────────────
const pageTitle       = seoEntry?.data.titleHe       ?? t(lang, 'site.photographerNameHe');
const pageDescription = seoEntry?.data.descriptionHe ?? '';
const canonicalUrl    = 'https://yaelcohen.photography/about';
---

<BaseLayout
  lang={lang}
  dir={dir}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  canonicalUrl={canonicalUrl}
>
  {aboutContent && (
    <AboutContent lang={lang} content={aboutContent} />
  )}
</BaseLayout>
