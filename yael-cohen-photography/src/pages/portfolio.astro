---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryFilter from '../components/GalleryFilter.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import Lightbox from '../components/Lightbox.astro';
import { t } from '../i18n/utils';

const lang = 'he' as const;
const dir  = 'rtl';

// ── CMS data ────────────────────────────────────────────────────────────────
const seoEntries = await getCollection('pagesSeo');
const seoEntry   = seoEntries.find(e => e.data.page === 'portfolio');

const allPhotos  = await getCollection('gallery');
const photos     = allPhotos
  .filter(p => p.data.published)
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder)
  .map(p => p.data);

// ── SEO values ───────────────────────────────────────────────────────────────
const pageTitle       = seoEntry?.data.titleHe       ?? t(lang, 'site.photographerNameHe');
const pageDescription = seoEntry?.data.descriptionHe ?? '';
const canonicalUrl    = 'https://yaelcohen.photography/portfolio';
---

<BaseLayout
  lang={lang}
  dir={dir}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  canonicalUrl={canonicalUrl}
>
  <div class="portfolio-page section">
    <div class="section-inner">
      <h1 class="portfolio-heading">
        {t(lang, 'portfolio.heading')}
      </h1>
      <span class="gold-rule" aria-hidden="true"></span>
      <GalleryFilter lang={lang} />
      <GalleryGrid photos={photos} lang={lang} />
    </div>
  </div>
  <Lightbox lang={lang} />
</BaseLayout>

<style>
  .portfolio-page {
    padding-block-start: calc(72px + var(--space-10));
  }

  .portfolio-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    color: var(--color-text-primary);
    margin-block-end: var(--space-5);
    line-height: 1.1;
  }
</style>
