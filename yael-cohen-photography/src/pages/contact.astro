---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { t } from '../i18n/utils';

const lang = 'he' as const;
const dir  = 'rtl';

// ── CMS data ─────────────────────────────────────────────────────────────────
const seoEntries = await getCollection('pagesSeo');
const seoEntry   = seoEntries.find(e => e.data.page === 'contact');

// ── SEO values ────────────────────────────────────────────────────────────────
const pageTitle       = seoEntry?.data.titleHe       ?? t(lang, 'site.photographerNameHe');
const pageDescription = seoEntry?.data.descriptionHe ?? '';
const canonicalUrl    = 'https://yaelcohen.photography/contact';
---

<BaseLayout
  lang={lang}
  dir={dir}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  canonicalUrl={canonicalUrl}
>
  <div class="contact-page section">
    <div class="section-inner contact-inner">
      <span class="gold-rule" aria-hidden="true"></span>
      <h1 class="contact-heading">
        {t(lang, 'contact.heading')}
      </h1>
      <div class="contact-body">
        <ContactForm lang={lang} />
        <div class="contact-whatsapp">
          <WhatsAppButton lang={lang} />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    padding-block-start: calc(72px + var(--space-10));
    padding-block-end: var(--space-14);
  }

  .contact-inner {
    max-width: 800px;
  }

  .contact-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-text-primary);
    margin-block-end: var(--space-9);
    line-height: 1.1;
  }

  .contact-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-whatsapp {
    padding-block-start: var(--space-6);
    border-block-start: 1px solid var(--color-border);
  }
</style>
