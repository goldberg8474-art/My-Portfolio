---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// Embed cloud name at build time so the client script can construct URLs
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? '';
const transform = 'w_1400,f_auto,q_auto';

const labelClose = t(lang, 'portfolio.lightbox.close');
const labelPrev  = t(lang, 'portfolio.lightbox.prev');
const labelNext  = t(lang, 'portfolio.lightbox.next');
const labelDialog = t(lang, 'portfolio.lightbox.ariaLabel');
---

<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label={labelDialog}
  aria-hidden="true"
  data-cloudname={cloudName}
  data-transform={transform}
>
  <!-- Backdrop (click outside image to close) -->
  <div class="lightbox-backdrop" id="lightbox-backdrop" aria-hidden="true"></div>

  <!-- Image container -->
  <div class="lightbox-content">
    <img
      class="lightbox-img"
      id="lightbox-img"
      src=""
      alt=""
      width="1400"
      height="933"
      decoding="async"
    />
  </div>

  <!-- Close button -->
  <button
    class="lightbox-btn lightbox-close"
    id="lightbox-close"
    type="button"
    aria-label={labelClose}
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true" focusable="false">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Prev button — inset-inline-start positions it at the "start" edge:
       left in LTR, right in RTL. This matches the spec. -->
  <button
    class="lightbox-btn lightbox-prev"
    id="lightbox-prev"
    type="button"
    aria-label={labelPrev}
  >
    <svg width="20" height="36" viewBox="0 0 20 36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <polyline points="16 4 4 18 16 32"/>
    </svg>
  </button>

  <!-- Next button — inset-inline-end positions it at the "end" edge:
       right in LTR, left in RTL. -->
  <button
    class="lightbox-btn lightbox-next"
    id="lightbox-next"
    type="button"
    aria-label={labelNext}
  >
    <svg width="20" height="36" viewBox="0 0 20 36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <polyline points="4 4 16 18 4 32"/>
    </svg>
  </button>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-lightbox);
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    cursor: zoom-out;
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: calc(100vw - var(--space-16));
    max-height: calc(100vh - var(--space-13));
    padding-inline: var(--space-12);
  }

  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - var(--space-13));
    width: auto;
    height: auto;
    object-fit: contain;
    border: none;
    box-shadow: none;
  }

  /* ── Shared button styles ─────────────────────────────────────────────── */
  .lightbox-btn {
    position: absolute;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: var(--space-3);
    min-height: 44px;
    min-width: 44px;
    transition: var(--transition-color);
  }

  .lightbox-btn:hover,
  .lightbox-btn:focus-visible {
    color: var(--color-text-primary);
  }

  .lightbox-btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* ── Close — top end corner ───────────────────────────────────────────── */
  .lightbox-close {
    inset-block-start: var(--space-5);
    inset-inline-end: var(--space-5);
  }

  /* ── Prev — vertical center, inline start ─────────────────────────────── */
  .lightbox-prev {
    inset-block-start: 50%;
    inset-inline-start: var(--space-4);
    transform: translateY(-50%);
  }

  /* ── Next — vertical center, inline end ──────────────────────────────── */
  .lightbox-next {
    inset-block-start: 50%;
    inset-inline-end: var(--space-4);
    transform: translateY(-50%);
  }
</style>

<script>
  interface PhotoEntry {
    cloudinaryId: string;
    altText: string;
  }

  // ── Collect photo data from the gallery grid ─────────────────────────────
  const galleryBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-photo-index]')
  );

  const photos: PhotoEntry[] = galleryBtns.map(btn => ({
    cloudinaryId: btn.dataset.cloudinaryId ?? '',
    altText:      btn.getAttribute('aria-label') ?? '',
  }));

  // ── Get lightbox elements ─────────────────────────────────────────────────
  const lightbox   = document.getElementById('lightbox') as HTMLElement;
  const backdrop   = document.getElementById('lightbox-backdrop') as HTMLElement;
  const img        = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn   = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn    = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn    = document.getElementById('lightbox-next') as HTMLButtonElement;

  // ── Build Cloudinary URL from the embedded data attributes ───────────────
  const cloudName  = lightbox.dataset.cloudname ?? '';
  const transform  = lightbox.dataset.transform ?? '';

  function buildUrl(publicId: string): string {
    return `https://res.cloudinary.com/${cloudName}/image/upload/${transform}/${publicId}`;
  }

  // ── State ─────────────────────────────────────────────────────────────────
  let currentIndex = 0;
  let lastFocused: HTMLElement | null = null;

  // ── Open / close ─────────────────────────────────────────────────────────
  function openLightbox(index: number): void {
    currentIndex = index;
    showPhoto(currentIndex);
    lightbox.classList.add('is-open');
    lightbox.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeLightbox(): void {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    img.src = '';
    lastFocused?.focus();
  }

  function showPhoto(index: number): void {
    const photo = photos[index];
    if (!photo) return;
    img.src = buildUrl(photo.cloudinaryId);
    img.alt = photo.altText;
  }

  function showPrev(): void {
    currentIndex = (currentIndex - 1 + photos.length) % photos.length;
    showPhoto(currentIndex);
  }

  function showNext(): void {
    currentIndex = (currentIndex + 1) % photos.length;
    showPhoto(currentIndex);
  }

  // ── Event listeners ───────────────────────────────────────────────────────
  galleryBtns.forEach((btn, index) => {
    btn.addEventListener('click', () => {
      lastFocused = btn;
      openLightbox(index);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);
  prevBtn.addEventListener('click', showPrev);
  nextBtn.addEventListener('click', showNext);

  // Click the backdrop (not the image) to close
  backdrop.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape')      { closeLightbox(); }
    else if (e.key === 'ArrowLeft')  { showPrev(); }
    else if (e.key === 'ArrowRight') { showNext(); }
  });
</script>
