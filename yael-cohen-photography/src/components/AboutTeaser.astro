---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  teaserText: string;
}

const { lang, teaserText } = Astro.props;

const aboutHref = lang === 'he' ? '/about' : '/en/about';
---

<section class="about-teaser section">
  <div class="about-teaser-inner section-inner">
    <span class="gold-rule" aria-hidden="true"></span>
    <h2 class="about-teaser-heading">
      {t(lang, 'home.about.heading')}
    </h2>
    <p class="about-teaser-text">{teaserText}</p>
    <a href={aboutHref} class="btn-outline">
      {t(lang, 'home.about.readMore')}
    </a>
  </div>
</section>

<style>
  .about-teaser {
    padding-block: var(--space-14);
  }

  .about-teaser-inner {
    max-width: 800px;
  }

  .about-teaser-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--color-text-primary);
    margin-block-end: var(--space-6);
    line-height: 1.1;
  }

  .about-teaser-text {
    font-size: 18px;
    line-height: 1.85;
    color: var(--color-text-secondary);
    margin-block-end: var(--space-8);
    max-width: 68ch;
  }
</style>
