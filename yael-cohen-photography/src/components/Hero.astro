---
import { t } from '../i18n/utils';
import { buildCloudinaryUrl, TRANSFORM_HERO } from '../lib/cloudinary';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const heroBgUrl = buildCloudinaryUrl('samples/landscapes/beach-boat', TRANSFORM_HERO);

const nameHe  = t(lang, 'site.photographerNameHe');
const nameEn  = t(lang, 'site.photographerNameEn');
const taglineHe = t(lang, 'site.taglineHe');
const taglineEn = t(lang, 'site.taglineEn');
---

<section
  class="hero"
  style={`background-image: url('${heroBgUrl}');`}
  aria-label={nameEn}
>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-names">
      <h1 class="hero-name-he" lang="he">{nameHe}</h1>
      <p class="hero-name-en" lang="en">{nameEn}</p>
    </div>

    <div class="hero-tagline" aria-label={`${taglineHe} ${taglineEn}`}>
      <span class="tagline-he" lang="he">{taglineHe}</span>
      <span class="tagline-sep" aria-hidden="true"></span>
      <span class="tagline-en" lang="en">{taglineEn}</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span class="hero-scroll-line"></span>
    <svg class="hero-scroll-chevron" width="16" height="10" viewBox="0 0 16 10" fill="none">
      <path d="M1 1l7 7 7-7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-5);
    gap: var(--space-6);
  }

  .hero-names {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .hero-name-he {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(3rem, 8vw, 7rem);
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.05;
    letter-spacing: 0.01em;
  }

  .hero-name-en {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(1.25rem, 3vw, 2.5rem);
    color: var(--color-text-secondary);
    margin: 0;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  /* Gold rule between Hebrew name and English name */
  .hero-names::after {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background-color: var(--color-gold);
    margin-block-start: var(--space-3);
  }

  .hero-tagline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .tagline-he {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: var(--color-gold);
    letter-spacing: 0.06em;
    font-style: italic;
  }

  .tagline-sep {
    display: block;
    width: 20px;
    height: 1px;
    background-color: var(--color-border);
  }

  .tagline-en {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(0.85rem, 2vw, 1.2rem);
    color: var(--color-text-secondary);
    letter-spacing: 0.1em;
    font-style: italic;
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    inset-block-end: var(--space-8);
    inset-inline-start: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    animation: scrollBounce 2.4s ease-in-out infinite;
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--color-text-secondary));
  }

  .hero-scroll-chevron {
    opacity: 0.6;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.6; }
    50%       { transform: translateX(-50%) translateY(6px); opacity: 1; }
  }
</style>
