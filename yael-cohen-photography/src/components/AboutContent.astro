---
import { buildCloudinaryUrl, TRANSFORM_PORTRAIT } from '../lib/cloudinary';
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface AboutData {
  bioHe: string;
  bioEn: string;
  profileImageCloudinaryId: string;
  servicesHe: string[];
  servicesEn: string[];
}

interface Props {
  lang: Locale;
  content: AboutData;
}

const { lang, content } = Astro.props;

const portraitUrl = buildCloudinaryUrl(content.profileImageCloudinaryId, TRANSFORM_PORTRAIT);
const bioText     = lang === 'he' ? content.bioHe : content.bioEn;
const services    = lang === 'he' ? content.servicesHe : content.servicesEn;
const bioParagraphs = bioText.split('\n\n').filter(p => p.trim().length > 0);

const photographerName = lang === 'he'
  ? t(lang, 'site.photographerNameHe')
  : t(lang, 'site.photographerNameEn');
---

<div class="about-layout section">
  <div class="about-inner section-inner">

    <!-- Two-column grid: portrait + bio.
         On RTL the browser mirrors the visual order automatically because
         the grid is not given an explicit column assignment — the natural
         inline flow direction handles it. -->
    <div class="about-columns">

      <!-- Portrait -->
      <div class="about-portrait-col">
        <div class="about-portrait-frame">
          <img
            src={portraitUrl}
            alt={photographerName}
            width="800"
            height="1000"
            loading="eager"
            decoding="async"
            class="about-portrait-img"
          />
        </div>
      </div>

      <!-- Biography + Services -->
      <div class="about-text-col">
        <span class="gold-rule" aria-hidden="true"></span>
        <h1 class="about-heading">
          {t(lang, 'about.heading')}
        </h1>

        <div class="about-bio">
          {bioParagraphs.map(para => (
            <p>{para}</p>
          ))}
        </div>

        <!-- Services -->
        <div class="about-services">
          <h2 class="about-services-heading">
            {t(lang, 'about.services.heading')}
          </h2>
          <ul class="services-list" role="list">
            {services.map(service => (
              <li class="services-item">
                <span class="services-bullet" aria-hidden="true">—</span>
                {service}
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .about-layout {
    padding-block-start: calc(72px + var(--space-10));
    padding-block-end: var(--space-14);
  }

  /* ── Two-column grid ──────────────────────────────────────────────────── */
  .about-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .about-columns {
      grid-template-columns: 380px 1fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  /* ── Portrait column ─────────────────────────────────────────────────── */
  .about-portrait-col {
    /* On mobile, portrait stacks above text naturally */
  }

  .about-portrait-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
  }

  /* Thin gold accent line along the inline-start edge of portrait */
  .about-portrait-frame::before {
    content: '';
    position: absolute;
    inset-block: var(--space-5);
    inset-inline-start: 0;
    width: 2px;
    background-color: var(--color-gold);
    z-index: 1;
  }

  .about-portrait-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    border: none;
  }

  /* ── Text column ─────────────────────────────────────────────────────── */
  .about-text-col {
    padding-block-start: var(--space-2);
  }

  .about-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-text-primary);
    margin-block-end: var(--space-8);
    line-height: 1.1;
  }

  .about-bio p {
    font-size: 18px;
    line-height: 1.9;
    color: var(--color-text-secondary);
    margin-block-end: var(--space-5);
  }

  .about-bio p:last-child {
    margin-block-end: 0;
  }

  /* ── Services ────────────────────────────────────────────────────────── */
  .about-services {
    margin-block-start: var(--space-10);
    padding-block-start: var(--space-8);
    border-block-start: 1px solid var(--color-border);
  }

  .about-services-heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--color-text-primary);
    margin-block-end: var(--space-6);
    line-height: 1.2;
  }

  .services-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .services-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    font-family: var(--font-body);
    font-weight: var(--font-weight-body-regular);
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .services-bullet {
    color: var(--color-gold);
    font-weight: var(--font-weight-body-medium);
    flex-shrink: 0;
    font-size: 1rem;
  }
</style>
