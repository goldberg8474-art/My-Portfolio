---
import { buildCloudinaryUrl, TRANSFORM_GALLERY_THUMB } from '../lib/cloudinary';
import type { Locale } from '../i18n/translations';

interface Photo {
  cloudinaryPublicId: string;
  titleHe: string;
  titleEn: string;
  altHe: string;
  altEn: string;
  category: string;
  displayOrder: number;
  published: boolean;
}

interface Props {
  photos: Photo[];
  lang: Locale;
}

const { photos, lang } = Astro.props;
---

<div class="gallery-grid" id="gallery-grid">
  {photos.map((photo, index) => {
    const thumbUrl  = buildCloudinaryUrl(photo.cloudinaryPublicId, TRANSFORM_GALLERY_THUMB);
    const altText   = lang === 'he' ? photo.altHe : photo.altEn;

    return (
      <div class="gallery-cell" data-category={photo.category}>
        <button
          class="gallery-btn"
          data-photo-index={index}
          data-cloudinary-id={photo.cloudinaryPublicId}
          aria-label={altText}
          type="button"
        >
          <img
            src={thumbUrl}
            alt={altText}
            width="600"
            height="400"
            loading="lazy"
            decoding="async"
            class="gallery-img"
          />
        </button>
      </div>
    );
  })}
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-cell {
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }

  .gallery-cell.is-hidden {
    display: none;
  }

  .gallery-btn {
    display: block;
    width: 100%;
    height: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
  }

  .gallery-btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: -2px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }

  .gallery-btn:hover .gallery-img {
    transform: scale(1.04);
  }
</style>
