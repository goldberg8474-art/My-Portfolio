# ─────────────────────────────────────────────────────────────────────────────
# Yael Cohen Photography — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# Never commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Your Cloudinary cloud name, found in the Cloudinary dashboard under
# Settings → Account. Used to construct image delivery URLs at build time
# and at runtime. No Cloudinary SDK is used — only URL construction.
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ── Resend (Email API) ────────────────────────────────────────────────────────
# Secret API key for the Resend email service (https://resend.com).
# Found in your Resend dashboard under API Keys. Keep this secret —
# it is only used server-side in the /api/contact endpoint and is never
# exposed to the browser.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The verified sender email address for outgoing contact form emails.
# This address MUST belong to a domain you have verified in the Resend
# dashboard (Resend → Domains). Sending from an unverified domain will
# cause all API calls to fail with a 403 error.
# Example: noreply@yaelcohen.photography
RESEND_FROM_EMAIL=noreply@yourdomain.com

# The email address that receives contact form submissions from visitors.
# This can be any valid email address — it does not need to be verified
# in Resend. Example: hello@yaelcohen.photography
RESEND_RECIPIENT_EMAIL=hello@yourdomain.com

# ── Tina CMS ─────────────────────────────────────────────────────────────────
# Tina Cloud project Client ID. Found in the Tina Cloud dashboard
# (https://app.tina.io) under your project → Configuration.
# This value is used server-side during the build (tinacms build) and
# also referenced by the admin bundle at runtime.
TINA_CLIENT_ID=your_tina_client_id

# Tina Cloud read/write token. Found in the Tina Cloud dashboard under
# your project → Tokens. Keep this secret — it grants write access to
# your content repository.
TINA_TOKEN=your_tina_token

# The same value as TINA_CLIENT_ID, repeated with the PUBLIC_ prefix so
# that Astro exposes it to the client-side Tina admin bundle in the browser.
# Astro only forwards environment variables to the browser if they start
# with PUBLIC_. The Tina admin UI requires this value at runtime.
PUBLIC_TINA_CLIENT_ID=your_tina_client_id
